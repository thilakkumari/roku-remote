#:kivy 2.2

<DiscoveryScreen>:
    canvas.before:
        Color:
            rgba: 0.05, 0.05, 0.1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: "24dp"
        spacing: "18dp"

        # ── Logo / title area ─────────────────────────────────────────────
        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "100dp"
            spacing: "6dp"

            Label:
                text: "Roku Remote"
                font_size: "32sp"
                bold: True
                color: 0.55, 0.38, 0.95, 1
                halign: "center"

            Label:
                text: "Control your TV from your phone"
                font_size: "13sp"
                color: 0.4, 0.4, 0.55, 1
                halign: "center"

        # ── Search button ─────────────────────────────────────────────────
        Button:
            text: "Search for Roku Devices"
            size_hint_y: None
            height: "52dp"
            font_size: "16sp"
            bold: True
            background_normal: ''
            background_down: ''
            background_color: 0.42, 0.28, 0.88, 1
            color: 1, 1, 1, 1
            on_press: root.start_discovery()

        # ── Device list ───────────────────────────────────────────────────
        ScrollView:
            GridLayout:
                id: device_list
                cols: 1
                spacing: "8dp"
                size_hint_y: None
                height: self.minimum_height

        # ── Status message ────────────────────────────────────────────────
        Label:
            id: status_label
            text: ""
            font_size: "14sp"
            size_hint_y: None
            height: "80dp"
            halign: "center"
            valign: "middle"
            text_size: self.size
            color: 0.4, 0.4, 0.58, 1

        Widget:
